# 2Minuts - Environment Variables
# Copy this file to .env.local and fill in the values

# AI Providers (future integration)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Database (future integration)
DATABASE_URL=

# Email (future integration)
SMTP_PASSWORD=

# Authentication
JWT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Monitoring (optional)
SENTRY_DSN=

# Rate Limiting - Upstash Redis (optional, falls back to in-memory)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
